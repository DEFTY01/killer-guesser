# Environment variables — copy to .env.local and fill in values

# ── Turso (libSQL) ────────────────────────────────────────────────
# Remote Turso database (production / staging):
DATABASE_URL=libsql://guesser-defty01.aws-eu-west-1.turso.io
DATABASE_AUTH_TOKEN=

# Local SQLite file (development — no Turso account needed):
